# Server
PORT=9527

# Local development database. Docker Compose production uses the MySQL variables below.
DB_TYPE=sqlite
DB_PATH=app.db

# Docker Compose MySQL defaults. Change these before production deployment.
MYSQL_DATABASE=kiroclaim
MYSQL_USER=kiroclaim
MYSQL_PASSWORD=change_me_to_a_strong_password
MYSQL_ROOT_PASSWORD=change_me_to_a_strong_root_password

# External MySQL example for manual docker run or non-compose deployment:
# DB_TYPE=mysql
# DB_DSN=kiroclaim:change_me@tcp(mysql-host:3306)/kiroclaim?charset=utf8mb4&parseTime=True&loc=Local

# Optional Prometheus metrics basic auth.
# METRICS_USER=
# METRICS_PASS=

# Check account health with the upstream service before delivery. Runtime settings override this value.
DISPATCH_HEALTH_CHECK_ENABLED=true

# Optional log bootstrap values. Runtime log rotation is managed in the admin settings page.
# LOG_FILE_ENABLED=true
# LOG_FILE_PATH=logs/app.log
# LOG_MAX_SIZE_MB=20
# LOG_MAX_BACKUPS=5
# LOG_MAX_AGE_DAYS=30
# LOG_COMPRESS=true
